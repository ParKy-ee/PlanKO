meta {
  name: Post-session-performance
  type: http
  seq: 2
}

post {
  url: {{api}}/session-performance
  body: json
  auth: inherit
}

body:json {
  {
    "plank_session_id": 1,
    "userId" : 21,
    "total_score": 1000,
    "duration": 2000,
    "accuracy_avg": 100,
    "perfect_count": 120,
    "good_count": 30,
    "bad_count": 10,
    "missed_count": 5,
    "kcal": 2200
  }
}

vars:pre-request {
  api: http://localhost:3001/api/v1
}

settings {
  encodeUrl: true
  timeout: 0
}
