meta {
  name: Post-program
  type: http
  seq: 2
}

post {
  url: {{api}}/program
  body: json
  auth: inherit
}

body:json {
  {
    "programName": "yamala",
    "programType": "Weightloss",
    "period": 200,
    "frequency": 2,
    "workDays": [1, 2],
    "restDays": [6, 7]
  }
}

vars:pre-request {
  api: http://localhost:3001/api/v1
}

settings {
  encodeUrl: true
  timeout: 0
}
